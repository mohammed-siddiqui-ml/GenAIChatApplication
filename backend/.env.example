# Application Settings
PROJECT_NAME="GenAI Knowledge Retrieval System"
ENVIRONMENT=development
API_VERSION=1.0.0
API_V1_PREFIX=/api/v1
DEBUG=true

# Server Settings
HOST=0.0.0.0
PORT=8000

# CORS Settings (comma-separated list)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Database Settings
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/knowledge_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Settings
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# JWT Authentication Settings
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours = 1440 minutes
ACCESS_TOKEN_EXPIRE_HOURS=24  # 24-hour expiry for JWT tokens
REFRESH_TOKEN_EXPIRE_DAYS=7

# GenAI Settings
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview  # GPT-4 Turbo for best quality
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=500

# Embedding Settings
EMBEDDING_MODEL=text-embedding-3-small  # text-embedding-3-small (1536 dimensions)
EMBEDDING_DIMENSION=1536

# Vector Database Settings (Qdrant)
VECTOR_DB_URL=http://localhost:6333
VECTOR_COLLECTION_NAME=knowledge_base

# Confluence Integration Settings
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_USERNAME=your-email@example.com
CONFLUENCE_API_TOKEN=your-confluence-api-token
CONFLUENCE_SPACE_KEY=YOUR_SPACE

# Issue Tracking Integration Settings (Jira)
JIRA_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=YOUR_PROJECT

# Data Ingestion Settings
INGESTION_SCHEDULE_CRON=0 2 * * *
INGESTION_BATCH_SIZE=100

# Performance Settings
MAX_RESPONSE_TIME_SECONDS=3.0
RATE_LIMIT_PER_MINUTE=60

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=json

# File Upload Settings
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,txt,md,docx,csv

# Sentry Error Tracking Settings
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1  # 10% of transactions for performance monitoring
SENTRY_ENABLE_TRACING=true
