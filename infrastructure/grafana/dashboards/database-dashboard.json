{
  "dashboard": {
    "title": "Database Performance Dashboard",
    "tags": ["database", "postgres", "performance"],
    "timezone": "browser",
    "editable": true,
    "graphTooltip": 1,
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
    },
    "panels": [
      {
        "id": 1,
        "title": "Connection Pool Usage",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "database_connection_pool_size{state=\"active\"}",
            "legendFormat": "Active Connections",
            "refId": "A"
          },
          {
            "expr": "database_connection_pool_size{state=\"idle\"}",
            "legendFormat": "Idle Connections",
            "refId": "B"
          },
          {
            "expr": "database_connection_pool_size{state=\"total\"}",
            "legendFormat": "Total Connections",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Connections"},
          {"format": "short"}
        ],
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true},
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [90], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "name": "Connection Pool Exhaustion Alert"
        }
      },
      {
        "id": 2,
        "title": "Query Duration (p95, p99)",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(database_query_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 {{operation}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, rate(database_query_duration_seconds_bucket[5m]))",
            "legendFormat": "p99 {{operation}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ],
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true}
      },
      {
        "id": 3,
        "title": "Cache Hit Rate (%)",
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "100 * (sum(rate(cache_operations_total{operation=\"get\",status=\"hit\"}[5m])) / sum(rate(cache_operations_total{operation=\"get\"}[5m])))",
            "legendFormat": "Cache Hit Rate",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "Hit Rate %", "max": 100, "min": 0},
          {"format": "short"}
        ],
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true},
        "thresholds": [
          {
            "value": 70,
            "colorMode": "critical",
            "op": "lt",
            "fill": true,
            "line": true
          }
        ]
      },
      {
        "id": 4,
        "title": "Cache Operations Rate",
        "type": "graph",
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(cache_operations_total{operation=\"get\",status=\"hit\"}[5m])",
            "legendFormat": "Cache Hits",
            "refId": "A"
          },
          {
            "expr": "rate(cache_operations_total{operation=\"get\",status=\"miss\"}[5m])",
            "legendFormat": "Cache Misses",
            "refId": "B"
          },
          {
            "expr": "rate(cache_operations_total{operation=\"set\"}[5m])",
            "legendFormat": "Cache Sets",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Operations/sec"},
          {"format": "short"}
        ],
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true}
      },
      {
        "id": 5,
        "title": "Database Query Rate by Operation",
        "type": "graph",
        "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(database_query_duration_seconds_count[5m])",
            "legendFormat": "{{operation}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "qps", "label": "Queries/sec"},
          {"format": "short"}
        ],
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true}
      },
      {
        "id": 6,
        "title": "PostgreSQL Active Connections",
        "type": "stat",
        "gridPos": {"x": 12, "y": 16, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "pg_stat_activity_count{state=\"active\"}",
            "legendFormat": "Active",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 50, "color": "yellow"},
                {"value": 80, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "PostgreSQL Idle Connections",
        "type": "stat",
        "gridPos": {"x": 18, "y": 16, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "pg_stat_activity_count{state=\"idle\"}",
            "legendFormat": "Idle",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 8,
        "title": "Cache Operation Duration",
        "type": "graph",
        "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(cache_operation_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 {{operation}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, rate(cache_operation_duration_seconds_bucket[5m]))",
            "legendFormat": "p99 {{operation}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      }
    ],
    "refresh": "10s",
    "schemaVersion": 27,
    "version": 1
  },
  "overwrite": true
}
