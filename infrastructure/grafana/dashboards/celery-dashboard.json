{
  "dashboard": {
    "title": "Celery Tasks Dashboard",
    "tags": ["celery", "tasks", "workers"],
    "timezone": "browser",
    "editable": true,
    "graphTooltip": 1,
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
    },
    "panels": [
      {
        "id": 1,
        "title": "Task Queue Depth",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "celery_queue_length",
            "legendFormat": "{{queue}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Queue Depth"},
          {"format": "short"}
        ],
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true, "max": true},
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [100], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "name": "High Queue Depth Alert"
        }
      },
      {
        "id": 2,
        "title": "Task Success/Failure Rate",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(celery_task_succeeded_total[5m])",
            "legendFormat": "Success Rate",
            "refId": "A"
          },
          {
            "expr": "rate(celery_task_failed_total[5m])",
            "legendFormat": "Failure Rate",
            "refId": "B"
          },
          {
            "expr": "rate(celery_task_retry_total[5m])",
            "legendFormat": "Retry Rate",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Tasks/sec"},
          {"format": "short"}
        ],
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true}
      },
      {
        "id": 3,
        "title": "Task Duration (p95, p99)",
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(celery_task_runtime_seconds_bucket[5m]))",
            "legendFormat": "p95 {{task}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, rate(celery_task_runtime_seconds_bucket[5m]))",
            "legendFormat": "p99 {{task}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ],
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true}
      },
      {
        "id": 4,
        "title": "Task Failure Rate (%)",
        "type": "graph",
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "100 * (sum(rate(celery_task_failed_total[5m])) / sum(rate(celery_task_total[5m])))",
            "legendFormat": "Failure Rate %",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "Failure Rate %"},
          {"format": "short"}
        ],
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true},
        "thresholds": [
          {
            "value": 5,
            "colorMode": "critical",
            "op": "gt",
            "fill": true,
            "line": true
          }
        ]
      },
      {
        "id": 5,
        "title": "Active Workers",
        "type": "stat",
        "gridPos": {"x": 0, "y": 16, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "celery_workers_active",
            "legendFormat": "Active Workers",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 1, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Task Execution Rate",
        "type": "stat",
        "gridPos": {"x": 6, "y": 16, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(rate(celery_task_total[5m]))",
            "legendFormat": "Tasks/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "decimals": 2
          }
        }
      },
      {
        "id": 7,
        "title": "Document Ingestion Tasks",
        "type": "graph",
        "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(document_ingestion_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 {{source_type}}",
            "refId": "A"
          },
          {
            "expr": "rate(documents_ingested_total{status=\"success\"}[5m])",
            "legendFormat": "Success: {{source_type}}",
            "refId": "B"
          },
          {
            "expr": "rate(documents_ingested_total{status=\"failed\"}[5m])",
            "legendFormat": "Failed: {{source_type}}",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Duration/Rate"},
          {"format": "short"}
        ],
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true}
      },
      {
        "id": 8,
        "title": "Task Queue Throughput",
        "type": "graph",
        "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(celery_task_sent_total[5m])",
            "legendFormat": "Tasks Sent",
            "refId": "A"
          },
          {
            "expr": "rate(celery_task_received_total[5m])",
            "legendFormat": "Tasks Received",
            "refId": "B"
          },
          {
            "expr": "rate(celery_task_started_total[5m])",
            "legendFormat": "Tasks Started",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Tasks/sec"},
          {"format": "short"}
        ],
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true}
      },
      {
        "id": 9,
        "title": "Worker Pool Utilization",
        "type": "gauge",
        "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "100 * (celery_worker_pool_active / celery_worker_pool_max)",
            "legendFormat": "Pool Utilization %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 70, "color": "yellow"},
                {"value": 90, "color": "red"}
              ]
            }
          }
        }
      }
    ],
    "refresh": "10s",
    "schemaVersion": 27,
    "version": 1
  },
  "overwrite": true
}
